<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="InnoShip\InnoShip\Api\ServiceInterface" type="InnoShip\InnoShip\Model\Api\Rest\Service"/>
    <preference for="InnoShip\InnoShip\Api\ApiOrderServiceInterface" type="InnoShip\InnoShip\Model\Api\Order"/>
    <preference for="InnoShip\InnoShip\Api\ApiLabelServiceInterface" type="InnoShip\InnoShip\Model\Api\Label"/>

    <type name="InnoShip\InnoShip\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>

    <type name="InnoShip\InnoShip\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">innoShipLogger</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">InnoShip\InnoShip\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="innoship_api_test_command" xsi:type="object">InnoShip\InnoShip\Console\Command\ApiTest</item>
                <item name="innoship_runimport" xsi:type="object">InnoShip\InnoShip\Console\Initialimport</item>
                <item name="innoship_runimportexternalid" xsi:type="object">InnoShip\InnoShip\Console\Importexternalid</item>
                <item name="innoship_regioimport" xsi:type="object">InnoShip\InnoShip\Console\Regioimport</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Checkout\Model\ShippingInformationManagement">
        <plugin name="InnoShip_InnoShipGo_Plugin_Frontend_Magento_Checkout_Model_ShippingInformationManagement"
                type="InnoShip\InnoShip\Plugin\Frontend\Magento\Checkout\Model\ShippingInformationManagement"
                sortOrder="10"
                disabled="false"/>
    </type>

    <type name="Magento\Quote\Model\Quote\Address\ToOrderAddress">
        <plugin name="InnoShip_InnoShipGo_Plugin_Magento_Quote_Model_Quote_Address_ToOrderAddress"
                type="InnoShip\InnoShip\Plugin\Magento\Quote\Model\Quote\Address\ToOrderAddress" sortOrder="99"
                disabled="false"/>
    </type>

    <type name="Magento\Payment\Model\MethodList">
        <plugin name="restrict_payment_on_shippingmethod"
                type="InnoShip\InnoShip\Plugin\Model\PaymentMethodAvailable" sortOrder="10"
                disabled="false"/>
    </type>

    <type name="Magento\Sales\Model\Order\Email\Container\Template">
        <plugin name="email.shipping.code"
                type="InnoShip\InnoShip\Plugin\Order\Email\Container\Template\EmailCode" sortOrder="100"
                disabled="false"/>
    </type>
</config>
