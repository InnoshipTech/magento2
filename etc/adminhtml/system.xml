                    <validate>validate-number validate-zero-or-greater</validate>
                </field>

                <field id="country_pudo_fees" translate="label comment" sortOrder="121" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Country Specific PUDO Fees</label>
                    <comment>Set handling fees for specific countries for PUDO/Locker delivery. Select country and enter fee amount.</comment>
                    <frontend_model>InnoShip\InnoShip\Block\Adminhtml\Form\Field\CountryPudoFees</frontend_model>
                    <backend_model>InnoShip\InnoShip\Model\Config\Backend\CountryFees</backend_model>
