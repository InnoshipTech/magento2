                    <validate>validate-number validate-zero-or-greater</validate>
                    <depends>
                        <field id="free_shipping_enable">1</field>
                    </depends>
                </field>

                <field id="check_if_available" translate="label" type="select" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Check if available</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="lungime" translate="label" type="text" sortOrder="151" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Atribut Lungime</label>
                    <depends>
                        <field id="check_if_available">1</field>
