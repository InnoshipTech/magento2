<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="innoship_shipment">
        <job name="innoship_shipment_pudo" instance="InnoShip\InnoShip\Cron\Pudoinnoship" method="execute">
            <schedule>30 * * * *</schedule>
        </job>
        <job name="innoship_shipment_courierid" instance="InnoShip\InnoShip\Cron\Courierlist" method="execute">
            <schedule>30 * * * *</schedule>
        </job>
        <job name="innoship_shipment_citylist" instance="InnoShip\InnoShip\Cron\Citylist" method="execute">
            <schedule>00 03 * * 0</schedule>
        </job>
        <job name="innoship_shipment_externalid" instance="InnoShip\InnoShip\Cron\ExternalIdSync" method="execute">
            <schedule>00 01 * * *</schedule>
        </job>
    </group>
</config>
