<?php
/** @var Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
/** @var InnoShip\InnoShip\Block\Frontend\Allowlocker $block */

// SECURITY: Properly encode JSON for JavaScript context to prevent XSS
// Use json_encode with proper flags to ensure safe output in script tags
$json = json_encode($block->getAllowCountryLocker(), JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);
$scriptString = <<<script
    window.allowCountryLocker = {$json};
script;
echo $secureRenderer->renderTag('script', [], $scriptString, false);
