<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="checkout"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <script src="InnoShip_InnoShip::js/checkout.js"/>
        <css src="InnoShip_InnoShip::css/leaflet.css"/>
        <css src="InnoShip_InnoShip::css/style.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="InnoShip\InnoShip\Block\Frontend\Showcourierlist" name="showcourierlist" template="InnoShip_InnoShip::showcourierlist.phtml"/>
            <block class="InnoShip\InnoShip\Block\Frontend\Allowlocker" name="allowloker" template="InnoShip_InnoShip::allowlocker.phtml"/>
        </referenceContainer>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="billing-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="additional-payment-validators" xsi:type="array">
                                                            <item name="children" xsi:type="array">
                                                                <!-- Declare your validation. START -->
                                                                <item name="easyboxValidation" xsi:type="array">
                                                                    <item name="component" xsi:type="string">InnoShip_InnoShip/js/view/isEasybox</item>
                                                                </item>
                                                                <!-- Declare your validation. END -->
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
